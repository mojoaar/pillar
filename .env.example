# App Environment
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database Configuration (SQLite with WAL safety)
# For Docker, this path should point to the mounted persistent /data directory
DATABASE_URL="file:./prisma/dev.db?connection_limit=1"

# NextAuth.js Configuration
# Generate secure secret: openssl rand -base64 48
NEXTAUTH_SECRET="your_nextauth_jwt_and_session_signing_secret_here"
NEXTAUTH_URL="http://localhost:3000"

# Encryption Key (AES-256-GCM)
# Required to encrypt passwords, SSH private keys, passphrases, and TOTP MFA secrets
# Generate a 32-byte hex key: openssl rand -hex 32 (64 hex characters)
ENCRYPTION_KEY="your_64_character_hex_encryption_key_here"

# Webhook DNS/SSRF configuration (Optional)
# ALLOW_LOCAL_IPS=false
