datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String             @id @default(uuid())
  email        String             @unique
  name         String?
  username     String             @unique
  role         String             @default("USER") // ADMIN or USER
  passwordHash String
  avatarUrl    String?
  mfaSecret    String?            // encrypted AES-256-GCM
  mfaEnabled   Boolean            @default(false)
  mfaEnforced  Boolean            @default(false)
  mfaBackupCodes String?          // encrypted AES-256-GCM comma-separated codes
  isSuspended  Boolean            @default(false)
  allowedPlugins String?           // comma-separated plugin IDs authorized for USER role (Phase 11)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  
  connections  Connection[]       @relation("UserConnections")
  sharedWithMe SharedConnection[]
  auditLogs    AuditLog[]
}

model Connection {
  id           String             @id @default(uuid())
  userId       String
  name         String
  host         String
  port         Int                @default(22)
  protocol     String             @default("SSH")      // SSH or VNC
  tags         String?            // comma-separated tags e.g. "prod,web,pve"
  username     String
  authType     String             @default("PASSWORD") // PASSWORD or KEY
  password     String?            // encrypted AES-256-GCM
  privateKey   String?            // encrypted AES-256-GCM
  passphrase   String?            // encrypted AES-256-GCM
  isShared     Boolean            @default(false)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  user         User               @relation("UserConnections", fields: [userId], references: [id], onDelete: Cascade)
  sharedWith   SharedConnection[]
}

model SharedConnection {
  connectionId String
  userId       String
  createdAt    DateTime @default(now())

  connection   Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([connectionId, userId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  event     String
  ip        String?
  meta      String?  // JSON stringified metadata
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Plugin {
  id        String   @id // e.g. "proxmox-ve"
  enabled   Boolean  @default(false)
  config    String?  // JSON string encrypted using AES-256-GCM
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
